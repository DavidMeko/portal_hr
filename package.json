{
  "name": "hr-portal",
  "version": "1.0.0",
  "description": "HR Portal Application",
  "main": "main.js",
  "scripts": {
  "start": "electron .",
  "build": "webpack --mode production",
  "dev": "webpack --mode development && electron .",
  "electron-dev": "concurrently \"webpack --mode development --watch\" \"electron .\"",
  "pack": "electron-builder --dir",
  "dist": "electron-builder"
  },
  "build": {
    "appId": "com.yourcompany.hrportal",
    "productName": "HR Portal",
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "index.html",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sqlite3/lib/binding/napi-v6-win32-x64",
        "to": "sqlite3",
        "filter": [
          "*.node"
        ]
      }
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "publish": {
      "provider": "generic",
      "url": "\\\\ism\\hr\\IT\\portalHR\\update"
    },
    "directories": {
      "output": "release-builds"
  }
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@date-io/date-fns": "^1.3.13",
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.12.1",
    "@mui/x-data-grid": "^6.0.0",
    "@mui/x-date-pickers": "^7.12.0",
    "bcrypt": "^5.1.0",
    "date-fns": "^2.30.0",
    "electron-updater": "^6.2.1",
    "exceljs": "^4.3.0",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.21",
    "pdfkit": "^0.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.10.0",
    "sqlite3": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@babel/preset-env": "^7.21.4",
    "@babel/preset-react": "^7.18.6",
    "babel-loader": "^9.1.2",
    "concurrently": "^8.0.1",
    "css-loader": "^6.7.3",
    "electron": "^24.1.2",
    "electron-builder": "^24.13.3",
    "electron-updater": "^5.3.0",
    "jest": "^29.5.0",
    "style-loader": "^3.3.2",
    "wait-on": "^7.0.1",
    "webpack": "^5.80.0",
    "webpack-cli": "^5.0.2"
  }
}
